# ============================================================
# نسق — Nasaq Environment Variables
# Copy to .env and fill in values
# ============================================================

# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nasaq?sslmode=require

# API
PORT=3000
NODE_ENV=development
APP_VERSION=0.1.0

# Dashboard
DASHBOARD_URL=http://localhost:5173

# Auth
# Set DEV_AUTH_BYPASS=true ONLY in local development to allow X-Org-Id / X-User-Id header bypass
# NEVER set to true in production — defaults to false
DEV_AUTH_BYPASS=false

# Field-level encryption key (AES-256-GCM) — used for integration credentials
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — 64 hex characters (32 bytes)
ENCRYPTION_KEY=

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nasaq-files
R2_PUBLIC_URL=

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# Payment - Moyasar
MOYASAR_API_KEY=
MOYASAR_PUBLISHABLE_KEY=
# Webhook secret — copy from Moyasar dashboard → Webhooks → shared_secret
MOYASAR_WEBHOOK_SECRET=
# Verification mode: log (safe rollout) | strict (enforce) | disabled (emergency kill)
MOYASAR_WEBHOOK_VERIFICATION=log
# Nasaq VAT number — يظهر في فاتورة الاشتراك
NASAQ_VAT_NUMBER=
