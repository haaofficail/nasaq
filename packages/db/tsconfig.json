{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["*.ts", "schema/**/*.ts", "scripts/**/*.ts", "seeds/**/*.ts"],
  "exclude": ["node_modules", "migrations"]
}
